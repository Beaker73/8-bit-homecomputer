{
  "$schema": "./nanoasm.schema.json",
  "name": "beaker8",
  "width": 8,
  "vars": {
    "dreg": { "bits":3, "toks": [ "r0", "r1", "r2", "r3", "r4", "r5", "sp", "pc" ] },
    "areg": { "bits":5, "toks": [
      "r0", "r1", "r2", "r3", "r4", "r5", "sp", "pc",
      "--(r0)", "--(r1)", "--(r2)", "--(r3)", "--(r4)", "--(r5)", "--(sp)", "--(pc)",
      "(r0)++", "(r1)++", "(r2)++", "(r3)++", "(r4)++", "(r5)++", "(sp)++", "(pc)++",
      "(r0)", "(r1)", "(r2)", "(r3)", "(r4)", "(r5)", "(sp)", "(pc)"
    ] }
  },
  "rules":[
    { "fmt": "ld ~areg, ~areg",     "bits": [ "000000", 0, 1 ] },
    { "fmt": "push ~dreg",          "bits": [ "000000", "01110", "00", 0 ] },
    { "fmt": "pop ~dreg",           "bits": [ "000000", "00", 0, "10110" ] }
  ]
}
